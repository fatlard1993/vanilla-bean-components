{
	"name": "@vanilla-bean/components",
	"version": "1.0.1",
	"type": "module",
	"module": "./index.js",
	"types": "./index.d.ts",
	"exports": {
		"./Component": "./Component/index.js",
		"./Elem": "./Elem/index.js",
		"./styled": "./styled/index.js",
		"./plugins/*": "./plugins/*.js",
		"./theme/*": "./theme/*.js",
		"./theme": "./theme/index.js",
		"./utils/*": "./utils/*.js",
		"./utils": "./utils/index.js",
		"./package.json": "./package.json",
		"./FontWithASyntaxHighlighter-Regular.woff2": "./FontWithASyntaxHighlighter-Regular.woff2",
		"./eslint.config.cjs": "./eslint.config.cjs",
		"./prettier.config.cjs": "./prettier.config.cjs",
		"./spellcheck.config.cjs": "./spellcheck.config.cjs",
		"./test-setup.js": "./test-setup.js",
		".": "./index.js"
	},
	"files": [
		"/Elem/*.js",
		"/Component/*.js",
		"/styled/*.js",
		"/plugins/*.js",
		"/components/**/*",
		"/theme/**/*",
		"/utils/**/*",
		"index.js",
		"index.d.ts",
		"./FontWithASyntaxHighlighter-Regular.woff2",
		"!/components/**/demo.js",
		"!/components/**/*.test.js",
		"!/utils/**/*.test.js",
		"eslint.config.cjs",
		"prettier.config.cjs",
		"spellcheck.config.cjs",
		"test-setup.js"
	],
	"description": "A lightweight, reactive component library for building modern web applications with vanilla JavaScript",
	"keywords": [
		"components",
		"reactive",
		"vanilla-js",
		"proxy",
		"web-components",
		"ui",
		"no-framework",
		"dom"
	],
	"license": "MIT",
	"author": "justfatlard (https://github.com/fatlard1993)",
	"browserslist": [
		"Chrome >= 112",
		"Edge >= 112",
		"Firefox >= 117",
		"Safari >= 16.5"
	],
	"scripts": {
		"prepare": "bun run prepare:githooks && bun run build",
		"prepare:githooks": "[ -n \"$CI\" ] && exit 0 || (git config --local core.hooksPath .githooks || echo 'Can not set git hooks')",
		"start": "bun run dev",
		"dev": "bun run devTools/build.js && bun --hot demo/server.js",
		"build": "bun run build:clean && bun run build:index && bun run devTools/build.js",
		"build:index": "bun run devTools/updateComponentIndex.js && bun run devTools/updateDemoViewIndex.js && bun run build:types && bun run format",
		"build:types": "bun run devTools/buildTypes.js",
		"build:clean": "rm -rf ./*.asText ./demo/build/",
		"build:watch": "bun run build -- --watch",
		"create:component": "bun run devTools/createComponent.js",
		"lint": "bun --bun eslint",
		"lint:fix": "bun --bun eslint --fix",
		"format": "BROWSERSLIST_IGNORE_OLD_DATA=1 bun run lint:fix && bun --bun prettier --write . --log-level warn",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"version": "npm version"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fatlard1993/vanilla-bean-components.git"
	},
	"bugs": {
		"url": "https://github.com/fatlard1993/vanilla-bean-components/issues"
	},
	"homepage": "https://github.com/fatlard1993/vanilla-bean-components#readme",
	"dependencies": {
		"@ctrl/tinycolor": "^4.1.0",
		"@fontsource-variable/kode-mono": "^5.2.6",
		"@fortawesome/fontawesome-free": "^7.0.0",
		"@vanilla-bean/oxject": "^1.0.0",
		"nanoid": "^5.1.5"
	},
	"devDependencies": {
		"@vanilla-bean/hypertether": "^1.0.0",
		"baseline-browser-mapping": "^2.10.38",
		"caniuse-lite": "^1.0.30001799",
		"@eslint/compat": "^1.3.2",
		"@eslint/js": "^9.33.0",
		"@happy-dom/global-registrator": "^18.0.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.6.4",
		"@testing-library/user-event": "^14.6.1",
		"bun-types": "^1.2.20",
		"eslint": "^9.33.0",
		"eslint-plugin-compat": "^6.0.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^54.0.0",
		"eslint-plugin-spellcheck": "0.0.20",
		"eslint-plugin-testing-library": "^7.6.6",
		"eslint-plugin-unicorn": "^60.0.0",
		"eslint-plugin-write-good-comments": "^0.2.0",
		"globals": "^16.3.0",
		"emoji-js": "^3.8.1",
		"marked": "^16.1.2",
		"moresketchy": "wbern/MoreSketchy.js",
		"prettier": "^3.6.2"
	},
	"engines": {
		"node": ">=18"
	}
}
